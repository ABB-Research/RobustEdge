# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# InfluxDB connection
# Inside Docker Compose the host should be the service name (influxdb).
# When running the campaign script from the host, set this to localhost.
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_DB=appdb

# InfluxDB credentials (required)
INFLUXDB_ADMIN_USER=admin
# Default admin password used by the local docker-compose stack
INFLUXDB_ADMIN_PASSWORD=change_me_admin_password

# Optional non-admin app user (matches docker-compose defaults)
INFLUXDB_USER=appuser
INFLUXDB_USER_PASSWORD=appuserpw

# Grafana credentials
GF_SECURITY_ADMIN_USER=admin
# Default Grafana admin password used by the local docker-compose stack
GF_SECURITY_ADMIN_PASSWORD=admin

# Unix socket paths for direct simulator/controller communication (optional).
# If set, the simulator and controller will use UNIX domain sockets instead of TCP.
# Ensure the host `./sockets` directory is created and mounted into both containers.
MV_SERVER_UNIX=/sockets/mv.sock
PV_TELEMETRY_UNIX=/sockets/pv.sock